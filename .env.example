# =============================================================================
# TAILSCALE HOTSPOT CONFIGURATION
# =============================================================================
# Copy this file to .env and customize for your setup
# All configuration options are explained below

# =============================================================================
# TAILSCALE CONFIGURATION
# =============================================================================

# Set this to your Tailscale exit node hostname or IP
# Find available exit nodes with: tailscale status
# Or check the Tailscale admin console at https://login.tailscale.com/admin/machines
# Example formats:
#   - "my-desktop.tail12345.ts.net" (hostname)
#   - "100.64.0.2" (Tailscale IP)
EXIT_NODE="your-exit-node.tail12345.ts.net"

# =============================================================================
# HOTSPOT CONFIGURATION
# =============================================================================

# Wi-Fi network name that devices will see
# Choose something descriptive but not revealing
SSID="MyTailscaleHotspot"

# Wi-Fi password (WPA2-PSK, minimum 8 characters)
# Use a strong password with mixed case, numbers, and symbols
PASS="YourSecurePassword123"

# Hotspot IP range - adjust if conflicts with existing networks
# This defines the subnet for connected devices
# Common alternatives if this conflicts:
#   - "192.168.50.1/24" (192.168.50.0/24 network)
#   - "172.16.1.1/24" (172.16.1.0/24 network)
#   - "10.0.1.1/24" (10.0.1.0/24 network)
SUBNET_CIDR="10.77.0.1/24"

# Wi-Fi band selection
# Options:
#   - "bg" = 2.4GHz (better range and compatibility, slower speeds)
#   - "a"  = 5GHz (faster speeds, shorter range, less congested)
# Recommendation: Use "bg" for maximum device compatibility
BAND="bg"

# Wi-Fi channel selection
# For 2.4GHz (BAND="bg"): Use 1, 6, or 11 to avoid interference
#   - Channel 1: Good for areas with less congestion
#   - Channel 6: Most common default, may be congested
#   - Channel 11: Alternative if 1 and 6 are busy
# For 5GHz (BAND="a"): Many more options available (36, 40, 44, 48, etc.)
# Check what's available in your region with: iw phy phy0 info
CHANNEL="6"

# Wi-Fi regulatory domain (country code)
# This ensures compliance with local wireless regulations
# Common codes:
#   - US: United States
#   - GB: United Kingdom  
#   - DE: Germany
#   - FR: France
#   - CA: Canada
#   - AU: Australia
#   - JP: Japan
#   - NL: Netherlands
#   - SE: Sweden
#   - CH: Switzerland
# Full list: https://wireless.wiki.kernel.org/en/developers/regulatory/iso3166countrycodes
REG_DOMAIN="US"

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# Whether to save iptables rules permanently across reboots
# Options:
#   - "yes" = Install netfilter-persistent and save rules (recommended)
#   - "no"  = Rules will be lost on reboot (manual restart required)
PERSIST_RULES="yes"

# NetworkManager connection name for the hotspot
# This is the internal name used by NetworkManager
# Usually no need to change unless you have conflicts
HOTSPOT_NAME="Hotspot"

# Network interface names
# These should match your system's interface names
# Check with: ip link show

# Wi-Fi interface name (usually wlan0 for built-in Wi-Fi)
# If using USB Wi-Fi adapter, might be wlan1, wlan2, etc.
# Check with: iw dev
WLAN_IF="wlan0"

# Tailscale interface name (usually tailscale0)
# This is automatically created by Tailscale
# Check with: ip link show | grep tailscale
TS_DEV="tailscale0"

# =============================================================================
# ADVANCED NOTES
# =============================================================================

# Network Flow:
# Client Device → Wi-Fi Hotspot → Raspberry Pi → Tailscale → Exit Node → Internet
#                 (wlan0)         (routing)     (tailscale0)   (your server)

# IP Address Assignments:
# - Hotspot gateway: First IP in SUBNET_CIDR (e.g., 10.77.0.1)
# - Client devices: Remaining IPs in range (e.g., 10.77.0.2-254)
# - DHCP range is automatically calculated by NetworkManager

# Security Considerations:
# - Use strong passwords for both SSID and Tailscale
# - Consider enabling MAC address filtering for additional security
# - Regularly update Raspberry Pi OS and Tailscale
# - Monitor connected devices periodically

# Troubleshooting Tips:
# - If devices can't connect, try different channels (1, 6, 11)
# - If no internet access, verify exit node is online: tailscale status
# - For IP conflicts, change SUBNET_CIDR to different range
# - Check Wi-Fi AP support: iw list | grep -A 8 "Supported interface modes"
